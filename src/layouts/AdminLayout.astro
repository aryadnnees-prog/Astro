---
interface Props {
  title: string;
  activeTab: string;
}

const { title, activeTab } = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} - Librería Astro</title>
  <style is:global>
    :root {
      --bg: #fbf9ff;
      --panel: #ffffff;
      --text: #130552;
      --muted: #6c6592;
      --line: #e5dcf2;
      --brand: #991fa6;
      --brand-dark: #130552;
      --accent: #ea6dc9;
      --blue: #2441e1;
      --purple: #65026d;
      --danger: #d93d92;
      --ok: #16805d;
      --warn: #a36a00;
      --soft: #f8eafd;
      --shadow: 0 14px 32px rgba(19, 5, 82, 0.10);
    }

    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: 'Outfit', 'Inter', Arial, Helvetica, sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    /* Auth Shield Overlay */
    #auth-shield {
      position: fixed;
      inset: 0;
      background: var(--bg);
      z-index: 9999;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      font-weight: bold;
      color: var(--brand-dark);
    }
    
    .spinner {
      width: 40px;
      height: 40px;
      border: 4px solid var(--line);
      border-radius: 50%;
      border-top-color: var(--brand);
      animation: spin 1s ease-in-out infinite;
      margin-bottom: 15px;
    }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 16px 24px;
      background: rgba(255, 255, 255, 0.96);
      border-bottom: 1px solid var(--line);
      position: sticky;
      top: 0;
      z-index: 30;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      color: var(--brand-dark);
      font-weight: 900;
      text-decoration: none;
    }

    .brand-icon {
      display: grid;
      place-items: center;
      color: #fff;
      background: linear-gradient(135deg, var(--purple), var(--brand), var(--blue));
      position: relative;
      font-weight: 900;
      box-shadow: 0 10px 24px rgba(101, 2, 109, 0.24);
      width: 48px;
      height: 48px;
      border-radius: 14px;
      font-size: 27px;
    }

    .brand-icon::after {
      content: "";
      position: absolute;
      width: 42px;
      height: 12px;
      top: 11px;
      left: 3px;
      border: 3px solid var(--accent);
      border-top: 0;
      border-left-color: transparent;
      border-radius: 50%;
      transform: rotate(-16deg);
    }

    .brand-text {
      display: grid;
      line-height: 1.05;
    }

    .astro-word {
      font-size: 25px;
      letter-spacing: 5px;
      text-transform: uppercase;
    }

    .brand-text small {
      margin-top: 4px;
      color: var(--brand);
      font-size: 12px;
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    .top-actions {
      display: flex;
      align-items: center;
      gap: 20px;
      color: var(--muted);
      font-size: 14px;
    }

    .logout-btn {
      color: var(--danger);
      text-decoration: none;
      font-weight: bold;
      cursor: pointer;
    }

    .layout {
      display: grid;
      grid-template-columns: 240px 1fr;
      min-height: calc(100vh - 81px);
    }

    aside {
      background: linear-gradient(180deg, #130552 0%, #29006a 55%, #65026d 100%);
      color: white;
      padding: 18px 14px;
    }

    .role {
      padding: 12px;
      background: rgba(255, 255, 255, 0.10);
      border-radius: 8px;
      margin-bottom: 14px;
      font-size: 14px;
      line-height: 1.5;
    }

    nav {
      display: grid;
      gap: 8px;
    }

    .tab-btn {
      width: 100%;
      border: 0;
      cursor: pointer;
      text-align: left;
      padding: 12px;
      border-radius: 8px;
      background: transparent;
      color: #f1e9ff;
      font-size: 15px;
      text-decoration: none;
      display: block;
      box-sizing: border-box;
      transition: all 0.2s ease;
    }

    .tab-btn:hover,
    .tab-btn.active {
      background: linear-gradient(135deg, var(--brand), var(--accent));
      color: white;
      box-shadow: 0 4px 10px rgba(153, 31, 166, 0.2);
    }

    main {
      padding: 24px;
      overflow-x: hidden;
    }

    .section-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 18px;
    }

    h1 {
      margin: 0;
      font-size: 26px;
    }

    h2 {
      margin: 0 0 14px;
      font-size: 18px;
    }

    .muted {
      color: var(--muted);
      font-size: 14px;
    }

    .access-note {
      display: inline-flex;
      align-items: center;
      min-height: 36px;
      padding: 0 12px;
      border: 1px solid var(--line);
      border-radius: 8px;
      background: var(--soft);
      color: var(--brand-dark);
      font-size: 13px;
      font-weight: 700;
    }

    .card {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 18px;
      box-shadow: var(--shadow);
    }

    .toolbar {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 14px;
    }

    input,
    select {
      min-height: 40px;
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 0 12px;
      background: white;
      color: var(--text);
      font-size: 14px;
      transition: border-color 0.2s;
    }

    input:focus, select:focus {
      outline: none;
      border-color: var(--brand);
    }

    button {
      min-height: 40px;
      border: 0;
      border-radius: 8px;
      padding: 0 14px;
      cursor: pointer;
      font-weight: 700;
      transition: all 0.2s ease;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--brand), var(--accent));
      color: white;
      box-shadow: 0 8px 18px rgba(153, 31, 166, 0.20);
    }

    .btn-primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 10px 20px rgba(153, 31, 166, 0.30);
    }

    .btn-secondary {
      background: #f2e9fb;
      color: var(--text);
    }

    .btn-secondary:hover {
      background: #e5d2f8;
    }

    .btn-danger {
      background: var(--danger);
      color: white;
    }

    .btn-danger:hover {
      background: #c2297f;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      overflow: hidden;
      background: white;
      border-radius: 8px;
    }

    th,
    td {
      padding: 12px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      font-size: 14px;
      vertical-align: middle;
    }

    th {
      background: #f8eafd;
      color: var(--brand-dark);
      font-size: 13px;
      text-transform: uppercase;
    }

    tr:last-child td { border-bottom: 0; }

    @media (max-width: 980px) {
      .layout { grid-template-columns: 1fr; }
      aside { padding: 12px; }
      nav { grid-template-columns: repeat(3, 1fr); }
    }

    @media (max-width: 620px) {
      header,
      .section-head {
        align-items: flex-start;
        flex-direction: column;
      }

      main { padding: 14px; }
      nav { grid-template-columns: 1fr 1fr; }
      input,
      select { width: 100%; }
    }
  </style>
</head>
<body>
  <!-- Escudo de Autenticación -->
  <div id="auth-shield">
    <div class="spinner"></div>
    <span>Verificando sesión...</span>
  </div>

  <header>
    <a href="/dashboard" class="brand">
      <div class="brand-icon">A</div>
      <div class="brand-text">
        <span class="astro-word">Astro</span>
        <small>Leer es descubrir mundos</small>
      </div>
    </a>
    <div class="top-actions">
      <span id="user-display">Usuario: ...</span>
      <a class="logout-btn" id="logoutBtn">Cerrar Sesión</a>
    </div>
  </header>

  <div class="layout">
    <aside>
      <div class="role">
        <strong>Rol activo</strong><br />
        <span id="role-display">Cargando...</span>
      </div>
      <nav>
        <a href="/dashboard" class={`tab-btn ${activeTab === 'dashboard' ? 'active' : ''}`}>Inicio</a>
        <a href="/productos" class={`tab-btn ${activeTab === 'productos' ? 'active' : ''}`}>Productos</a>
        <a href="/ventas" class={`tab-btn ${activeTab === 'ventas' ? 'active' : ''}`}>Ventas</a>
        <a href="/stock" class={`tab-btn ${activeTab === 'stock' ? 'active' : ''}`}>Stock</a>
        <a href="/pedidos" class={`tab-btn ${activeTab === 'pedidos' ? 'active' : ''}`}>Pedidos Online</a>
        <a href="/tienda" class="tab-btn">Tienda Online</a>
      </nav>
    </aside>

    <main>
      <slot />
    </main>
  </div>

  <script>
    import { supabase } from '../lib/supabase';

    const authShield = document.getElementById('auth-shield');
    const userDisplay = document.getElementById('user-display');
    const roleDisplay = document.getElementById('role-display');
    const logoutBtn = document.getElementById('logoutBtn');

    // Shield check
    supabase.auth.getSession().then(async ({ data: { session } }) => {
      if (!session) {
        window.location.href = '/';
        return;
      }

      // Obtener perfil del usuario para el rol y nombre
      const user = session.user;
      userDisplay.textContent = `Usuario: ${user.email}`;

      try {
        const { data: profile, error } = await supabase
          .from('perfiles')
          .select('nombre, rol')
          .eq('id', user.id)
          .single();

        if (profile) {
          userDisplay.textContent = `Usuario: ${profile.nombre || user.email}`;
          roleDisplay.textContent = profile.rol === 'admin' ? 'Administrador' : profile.rol;
        } else {
          roleDisplay.textContent = 'Usuario';
        }
      } catch (err) {
        roleDisplay.textContent = 'Administrador';
      }

      // Quitar escudo de carga
      authShield.style.display = 'none';
    });

    // Cerrar sesión
    logoutBtn.addEventListener('click', async () => {
      await supabase.auth.signOut();
      window.location.href = '/';
    });
  </script>
</body>
</html>
